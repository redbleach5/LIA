{
  "name": "lia-v2",
  "version": "0.3.1",
  "private": true,
  "scripts": {
    "dev": "node scripts/kill-port.mjs 3000 && next dev -H 127.0.0.1 -p 3000",
    "build": "next build",
    "build:standalone": "node scripts/build-standalone.mjs",
    "start": "cross-env NODE_ENV=production HOSTNAME=127.0.0.1 node .next/standalone/server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit --incremental false",
    "typecheck:tests": "tsc --noEmit -p tsconfig.tests.json",
    "check:scripts": "node scripts/check-scripts.mjs",
    "test": "vitest run --config vitest.config.mts",
    "test:watch": "vitest --config vitest.config.mts",
    "test:ci": "vitest run --config vitest.config.mts",
    "test:all": "bun run test",
    "test:safe:local": "node scripts/run-tests-safe.mjs",
    "dev:verbose": "node scripts/kill-port.mjs 3000 && cross-env LOG_LEVEL=debug next dev -H 127.0.0.1 -p 3000",
    "dev:quiet": "node scripts/kill-port.mjs 3000 && cross-env LOG_LEVEL=warn next dev -H 127.0.0.1 -p 3000",
    "logs:tail": "tail -f dev.log",
    "logs:agent": "grep -E '\\[agent\\]|\\[tools\\]' dev.log | tail -100",
    "logs:errors": "grep -E '\\[ERROR\\]' dev.log | tail -50",
    "diagnose": "node scripts/diagnose.mjs",
    "diagnose:verbose": "cross-env VERBOSE=1 node scripts/diagnose.mjs",
    "db:push": "node scripts/db-init.mjs",
    "db:force-push": "node scripts/db-init.mjs --force",
    "db:patch": "node scripts/lib/apply-schema-patches.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "logs:tail:win": "powershell -Command \"Get-Content dev.log -Wait -Tail 20\"",
    "logs:agent:win": "powershell -Command \"Select-String -Path dev.log -Pattern '\\[agent\\]|\\[tools\\]' | Select-Object -Last 100\"",
    "logs:errors:win": "powershell -Command \"Select-String -Path dev.log -Pattern '\\[ERROR\\]' | Select-Object -Last 50\"",
    "kb:backup": "node scripts/kb-backup.mjs",
    "kb:restore": "node scripts/kb-restore.mjs",
    "kb:e2e": "node scripts/kb-chat-e2e.mjs",
    "kb:export": "node scripts/kb-export.mjs",
    "kb:import": "node scripts/kb-export.mjs import",
    "ollama:backup": "node scripts/ollama-backup.mjs",
    "ollama:restore": "node scripts/ollama-restore.mjs",
    "commit:msg": "node scripts/commit-msg.mjs",
    "setup": "node scripts/setup.mjs",
    "setup:hooks": "node scripts/install-git-hooks.mjs",
    "postinstall": "node scripts/install-git-hooks.mjs && prisma generate"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^3.0.0",
    "@mozilla/readability": "^0.6.0",
    "@pixiv/three-vrm": "^3.5.4",
    "@prisma/client": "^6.11.1",
    "@radix-ui/react-alert-dialog": "^1.1.18",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "ai": "^7.0.2",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "jsdom": "^29.1.1",
    "lucide-react": "^0.525.0",
    "mammoth": "^1.12.0",
    "next": "^16.1.1",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "prisma": "^6.11.1",
    "re2": "^1.25.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "snowball-stemmers": "^0.6.0",
    "sonner": "^2.0.6",
    "sqlite-vec": "^0.1.9",
    "tailwind-merge": "^3.3.1",
    "three": "0.160.0",
    "zod": "^4.0.2",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsdom": "^28.0.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "0.160.0",
    "bun-types": "^1.3.4",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}

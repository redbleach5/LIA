# .env.example — скопируй в .env и заполни значения
#
# Все пути относительные — работают на macOS, Windows, Linux.
# Не используй абсолютные пути типа /home/user/... или C:\Users\... —
# они сломаются на другой машине.

# Database (SQLite path)
# IMPORTANT: Prisma resolves this RELATIVE TO prisma/schema.prisma location
# (i.e. Lia-v2-public/prisma/), so `file:../db/custom.db` → Lia-v2-public/db/custom.db.
#
# better-sqlite3 (used in src/lib/db-vec.ts) resolves paths via resolveDbPath()
# in src/lib/paths.ts. That function STRIPS leading "../" or "..\\" segments
# before joining against PROJECT_ROOT (process.cwd() or LIA_ROOT), so it also
# lands on Lia-v2-public/db/custom.db. Without the "../" prefix in DATABASE_URL,
# Prisma would resolve to Lia-v2-public/prisma/db/custom.db — a DIFFERENT file.
#
# Net effect: keep `file:../db/custom.db` — both layers open the same file,
# but for DIFFERENT reasons (Prisma needs "../" to escape prisma/; paths.ts
# compensates by stripping it). Earlier (file:./db/custom.db) the two layers
# disagreed and silently wrote to two different SQLite files.
#
# Use forward slashes — they work on all platforms including Windows.
DATABASE_URL=file:../db/custom.db

# Ollama — bootstrap defaults for first launch only (empty SQLite Settings).
# After the first save in Settings → Модель, SQLite is the source of truth;
# changing these lines will NOT override the UI until you clear those DB keys.
# Local: http://127.0.0.1:11434
# Remote GPU PC on LAN (also settable in Settings → Модель → Хост Ollama):
#   OLLAMA_BASE_URL=http://192.168.1.50:11434
# From work without a public IP — Tailscale (see REMOTE-OLLAMA.md in repo root):
#   OLLAMA_BASE_URL=http://100.x.x.x:11434
# On the GPU machine, bind Ollama: OLLAMA_HOST=0.0.0.0 ollama serve
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
# Optional stronger model for agent (plan/tools/synthesize). Empty = same as OLLAMA_MODEL.
# OLLAMA_AGENT_MODEL=qwen3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
# When Next.js UI runs on one machine and Ollama on another (LAN/Tailscale), set the
# inference box VRAM here so budget/tier don't use the UI laptop's Metal/GPU.
# Example: MacBook UI → home RTX 5060 Ti 16GB → LIA_INFERENCE_VRAM_GB=16
# LIA_INFERENCE_VRAM_GB=16
#
# Warmup (keeps models in VRAM). Safe on local Ollama; on remote GPU hosts
# chat preload is OFF by default so an idle Mac UI doesn't pin the workstation.
# LIA_WARMUP_ENABLED=true
# LIA_WARMUP_INTERVAL_MS=240000
# LIA_WARMUP_REMOTE_CHAT=true   # only if you want remote chat always resident

# Network boundary. Lia binds to 127.0.0.1 by default.
# Remote API access is disabled unless BOTH values are configured. The current
# browser UI is localhost-only because EventSource cannot attach this header;
# remote mode is intended for trusted API clients or a separately secured proxy.
# LIA_ALLOW_REMOTE=false
# LIA_INTERNAL_TOKEN=generate-a-long-random-token

# Optional: override project root detection
# By default, process.cwd() is used (works when `bun run dev` is called
# from the project root). Set LIA_ROOT if the process cwd is not the repo root.
# LIA_ROOT=/path/to/project

# Agent filesystem scope.
# Explicit fsScope from the client always wins.
# Otherwise: LIA_AGENT_DEFAULT_WORKSPACE → KB folder/codebase name match in goal
# → Lia root ONLY if goal mentions Lia OR LIA_AGENT_MOUNT_SELF=true
# → else write sandbox for coding goals (never silently mount Lia for other projects).
# LIA_AGENT_DEFAULT_WORKSPACE=C:\Users\User\Downloads\AgentsRise
# LIA_AGENT_MOUNT_SELF=false
# LIA_AGENT_SANDBOX_ONLY=false

# Logging level: trace | debug | info | warn | error
# Default: info в production, debug в development
# trace — все детали (для отладки конкретного бага)
# debug — детальные логи агента, инструментов, памяти (рекомендуется для dev)
# info — ключевые события (chat request, agent task started/done, tool calls)
# warn — только ошибки и предупреждения
# error — только ошибки
LOG_LEVEL=info

# LLM call timeouts (in milliseconds).
# На macOS arm64 с qwen2.5:7b генерация может занимать 60-180с.
# На мощных машинах с 70B-моделями — до 5 минут.
# Если агент таймаутит на step'ах — увеличь эти значения.
LIA_LLM_TIMEOUT_MS=180000          # 3 минуты для plan/execute
LIA_LLM_SYNTHESIS_TIMEOUT_MS=240000 # 4 минуты для synthesize (длиннее, т.к. генерирует финальный ответ)

# Encryption key для шифрования секретов at rest (YouTrack tokens и т.д.).
# 32 байта base64. Сгенерируй: openssl rand -base64 32
# БЕЗ этого ключа токены хранятся в plaintext в SQLite — приемлемо для
# изолированной dev-машины, но небезопасно для бэкапов/синхронизации/production.
# Потеря ключа = потеря доступа к зашифрованным секретам (нужно перевыпускать
# токены в YouTrack). Храни в password manager отдельно от БД.
# LIA_ENCRYPTION_KEY=

# Опционально: предыдущий ключ (для rotation). При расшифровке сначала
# пробуется текущий, при ошибке — предыдущий. После rotation удали.
# LIA_ENCRYPTION_KEY_PREVIOUS=

# ── Quality settings (wave 2) ──
# Эти настройки позволяют тонко настроить качество работы Лии для 8B-60B моделей.
# Defaults оптимизированы для single-user local-first с standard tier (8-12B).

# KB query rewrite — LLM переформулирует поисковый запрос перед searchKB.
# Улучшает recall для follow-up вопросов. +1-2s latency на 8B модели.
# Default: true (отключается автоматически для micro tier)
# LIA_KB_QUERY_REWRITE=true

# KB context expansion — добавляет parent + sibling chunks для лучшего контекста.
# Помогает для вопросов «что такое X?» когда определение в предыдущем chunk.
# Default: true (отключается автоматически для micro tier)
# LIA_KB_CONTEXT_EXPANSION=true

# KB highlighting — оборачивает совпавшие термины в <mark> для UI подсветки.
# Default: true
# LIA_KB_HIGHLIGHT=true

# KB deduplication — не дублирует chunks с одинаковым contentHash между sources.
# Default: true (для single-user — нет смысла хранить одинаковые embeddings 2 раза)
# LIA_KB_DEDUP=true

# Groundedness verifier for KB agent synthesis (lexical + optional LLM for uncertain claims).
# Set to 0/false to disable the LLM tier (lexical filter still runs).
# LIA_KB_VERIFY_LLM=true

# System prompt mode — какие секции включать в system prompt.
# - full: все playbook-секции + assistant-профиль (legacy «толстый» промпт)
# - adaptive: профиль companion/assistant по контексту (default)
# - minimal: только personality + rules + tier instructions
# LIA_SYSTEM_PROMPT=adaptive

# Принудительный профиль чата (обычно не нужен): minimal | companion | assistant
# LIA_CHAT_PROMPT_PROFILE=companion

# Dev/on-prem: разрешить HTTP для YouTrack baseUrl (token уйдёт в plaintext).
# НЕ рекомендуется для production. Default: false (HTTPS only).
# LIA_ALLOW_HTTP_YOUTRACK=false

# ── Wave 3: Reflection Engine + Field Encryption ──

# Reflection Engine — периодическая консолидация эмоциональной памяти.
# LLM обобщает похожие emotional anchors в summary, предотвращает деградацию
# векторного поиска при накоплении десятков/сотен anchors.
# Default: true
# LIA_REFLECTION_ENGINE=true

# Field-level encryption — шифрование чувствительных полей (emotional memory
# context/trigger, global/episode fact values) через AES-256-GCM.
# Требует LIA_ENCRYPTION_KEY. НЕ шифрует chat history и document content
# (performance constraint). Для full DB encryption используй OS-level:
# BitLocker (Windows), FileVault (macOS), LUKS (Linux).
# Default: false (backward compat)
# LIA_ENCRYPT_SENSITIVE_FIELDS=false

# LLM-as-judge tests (tests/llm-judge/) — модели Ollama для integration + judge
# Default: OLLAMA_MODEL или qwen2.5:7b
# LIA_TEST_MODEL=qwen2.5:7b
# LIA_JUDGE_MODEL=qwen2.5:7b
